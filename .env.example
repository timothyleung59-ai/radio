# ===== AI 模型 (Anthropic 兼容接口) =====
# 任意支持 messages.create 的 Anthropic-compatible 端点
# 比如 Claude 官方 / DeepSeek 的 anthropic 兼容代理 / MiMo 等
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_MODEL=deepseek-v4-flash

# ===== 网易云音乐 =====
# 本地起 NeteaseCloudMusicApi（npm run all 自动起）
NETEASE_API=http://localhost:3000
# 可选：网易云登录 cookie，用于"我喜欢的音乐"双向同步
# 浏览器登录网易云后从 DevTools 复制 MUSIC_U 那一段
NETEASE_COOKIE=

# ===== 火山引擎 TTS（豆包语音）=====
# 旧版控制台用 APPID + ACCESS_TOKEN（V1 HTTP 接口走这套）
# 控制台: https://console.volcengine.com → 豆包语音 → 应用管理
VOLC_APPID=
VOLC_ACCESS_TOKEN=
VOLC_CLUSTER=volcano_tts

# 推荐用 1.0 系列 _bigtts 大模型音色（V1 HTTP 直接支持）
# 完整列表: https://www.volcengine.com/docs/6561/1257544
VOLC_VOICE_TYPE=zh_female_wanwanxiaohe_moon_bigtts
# 服务端音量增益，范围 0.5–2.0；客户端再叠加 GainNode 1.8x
VOLC_VOLUME=2.0
# 留空走默认 1.0 倍速
VOLC_SPEED=
VOLC_PITCH=

# ===== 火山引擎 TTS · 新版控制台（可选）=====
# 新版控制台用 X-Api-Key 调 V3 WebSocket 双向流式接口
# 注意：V3 需要账号开通对应资源包（seed-tts-2.0 / seed-tts-1.0），未开通会静默 0 字节
# 设 VOLC_USE_V3=1 才走 V3，否则默认走 V1
VOLC_API_KEY=
# VOLC_USE_V3=1

# ===== 火山引擎 OpenAPI（可选，目前未启用）=====
# 用 IAM AccessKey + SecretKey 签 OpenAPI 请求，
# 例如查 quota、用量、自动开通资源包等管理面动作
VOLC_SECRET_KEY=

# ===== 服务器 =====
PORT=3001
