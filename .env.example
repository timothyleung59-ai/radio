# ===== AI 模型 (Anthropic 兼容接口) =====
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_BASE_URL=your_base_url_here
ANTHROPIC_MODEL=MiMo-V2.5-Pro

# ===== 网易云音乐 =====
NETEASE_API=http://localhost:3000
NETEASE_COOKIE=

# ===== 字节火山引擎 TTS（DJ 语音） =====
# 在 https://console.volcengine.com 开通「语音技术 → 语音合成」
# 创建应用后从 Apps 管理页拿到 APPID 和 Access Token
VOLC_APPID=
VOLC_ACCESS_TOKEN=
# 集群：常规走 volcano_tts；大模型/复刻音色走 volcano_icl
VOLC_CLUSTER=volcano_tts
# 音色 ID：BV001_streaming(通用女) / BV002_streaming(通用男) / BV700_streaming(灿灿) 等
VOLC_VOICE_TYPE=BV001_streaming
# 可选微调：语速/音量/音调（默认 1.0）
VOLC_SPEED=1.0
VOLC_VOLUME=1.0
VOLC_PITCH=1.0

# ===== 服务器 =====
PORT=3001
