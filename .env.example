# ===== AI 模型 (Anthropic 兼容接口) =====
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_BASE_URL=your_base_url_here
ANTHROPIC_MODEL=MiMo-V2.5-Pro

# ===== 网易云音乐 =====
NETEASE_API=http://localhost:3000
NETEASE_COOKIE=

# ===== 小米 MiMo-V2.5-TTS（DJ 语音 · 当前默认） =====
# 控制台: https://platform.xiaomimimo.com  → 拿到 API Key 填到下面
MIMO_API_KEY=
MIMO_TTS_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_TTS_MODEL=mimo-v2.5-tts
# 内置音色: mimo_default | 冰糖 | 茉莉 | 苏打 | 白桦 | Mia | Chloe | Milo | Dean
MIMO_TTS_VOICE=mimo_default
# wav 浏览器可直接播放；pcm16 仅在自行解码时用
MIMO_TTS_FORMAT=wav
# 可选：默认风格指令（自然语言），客户端不传 style 时启用
MIMO_TTS_STYLE=

# ===== 字节火山引擎 TTS（旧实现，已不接线，保留以备回滚） =====
# 在 https://console.volcengine.com 开通「语音技术 → 语音合成」
# 创建应用后从 Apps 管理页拿到 APPID 和 Access Token
VOLC_APPID=
VOLC_ACCESS_TOKEN=
VOLC_CLUSTER=volcano_tts
VOLC_VOICE_TYPE=BV001_streaming
VOLC_SPEED=1.0
VOLC_VOLUME=1.0
VOLC_PITCH=1.0

# ===== 服务器 =====
PORT=3001
